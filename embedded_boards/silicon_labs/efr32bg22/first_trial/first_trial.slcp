# Silicon Labs Project Configuration Tools: slcp, v0, Component selection file.
project_name: first_trial
label: first_trial
description: |
  A minimal project structure, that serves as a starting point for custom Bluetooth applications. The application starts advertising after boot and restarts advertising after a connection is closed.
category: Bluetooth Examples
filter:
- name: Device Type
  value: [SoC]
- name: Project Difficulty
  value: [Beginner]
- name: Wireless Technology
  value: [Bluetooth]
package: Bluetooth
quality: production
readme:
- {path: 'C:/Users/sudharsan/SimplicityStudio/SDKs/gecko_sdk/app/bluetooth/example/bt_soc_empty/readme.md'}
source:
- {path: 'C:/Users/sudharsan/SimplicityStudio/SDKs/gecko_sdk/app/bluetooth/example/bt_soc_empty/main.c'}
- {path: 'C:/Users/sudharsan/SimplicityStudio/SDKs/gecko_sdk/app/bluetooth/example/bt_soc_empty/app.c'}
tag: ['hardware:rf:band:2400']
include:
- path: C:/Users/sudharsan/SimplicityStudio/SDKs/gecko_sdk/app/bluetooth/example/bt_soc_empty
  file_list:
  - {path: app.h}
sdk: {id: gecko_sdk, version: 4.5.0}
toolchain_settings: []
component:
- {id: EFR32BG22C224F512IM32}
- {id: app_assert}
- {id: bluetooth_feature_connection}
- {id: bluetooth_feature_gatt}
- {id: bluetooth_feature_gatt_server}
- {id: bluetooth_feature_legacy_advertiser}
- {id: bluetooth_feature_legacy_scanner}
- {id: bluetooth_feature_sm}
- {id: bluetooth_feature_system}
- {id: bluetooth_stack}
- {id: bootloader_interface}
- {id: bt_post_build}
- {id: component_catalog}
- {id: gatt_configuration}
- {id: gatt_service_device_information}
- {id: in_place_ota_dfu}
- instance: [eusart_test]
  id: iostream_eusart
- {id: mpu}
- {id: rail_util_pti}
other_file:
- {path: 'C:/Users/sudharsan/SimplicityStudio/SDKs/gecko_sdk/app/bluetooth/example/bt_soc_empty/image/readme_img0.png',
  directory: image/}
- {path: 'C:/Users/sudharsan/SimplicityStudio/SDKs/gecko_sdk/app/bluetooth/example/bt_soc_empty/image/readme_img1.png',
  directory: image/}
- {path: 'C:/Users/sudharsan/SimplicityStudio/SDKs/gecko_sdk/app/bluetooth/example/bt_soc_empty/image/readme_img2.png',
  directory: image/}
- {path: 'C:/Users/sudharsan/SimplicityStudio/SDKs/gecko_sdk/app/bluetooth/example/bt_soc_empty/image/readme_img3.png',
  directory: image/}
- {path: 'C:/Users/sudharsan/SimplicityStudio/SDKs/gecko_sdk/app/bluetooth/example/bt_soc_empty/image/readme_img4.png',
  directory: image/}
template_contribution:
- {name: memory_ram_start, priority: 0, value: 0}
- {name: memory_ram_size, priority: 0, value: 0}
- {name: memory_flash_start, priority: 0, value: 0}
- {name: memory_flash_size, priority: 0, value: 0}
configuration:
- {name: SL_STACK_SIZE, value: '2752'}
- {name: SL_HEAP_SIZE, value: '9200'}
- condition: [psa_crypto]
  name: SL_PSA_KEY_USER_SLOT_COUNT
  value: '0'
ui_hints:
  highlight:
  - {path: config/btconf/gatt_configuration.btconf}
  - {path: readme.md, focus: true}

